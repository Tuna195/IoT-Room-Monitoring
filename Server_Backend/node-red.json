    {
        "id": "4caccb18b69d48e2",
        "type": "function",
        "z": "5c5e937acc317fb2",
        "name": "Split Time - Data",
        "func": "var rawString = msg.payload.toString().trim();\nvar parts = rawString.split(\",\");\n\nif (parts.length === 3) {\n    var epochSeconds = parseInt(parts[0]);\n    var tempVal = parseFloat(parts[1]); // ✅ ÉP FLOAT\n    var humidVal = parseFloat(parts[2]);\n    msg.measurement = \"sensor_data\";\n\n    msg.payload = {\n        nhiet_do: tempVal,\n        do_am: humidVal,\n        time: new Date(epochSeconds * 1000)\n    };\n\n    return msg;\n}\nreturn null;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1240,
        "y": 240,
        "wires": [
