        "id": "7ea92531e5040ebf",
        "type": "function",
        "z": "5c5e937acc317fb2",
        "name": "Insert_Data_InfluxDB",
        "func": "// Lấy giá trị\nvar value = parseFloat(msg.payload);\nvar topic = msg.topic; // Lấy topic để phân biệt\n\nmsg.measurement = \"sensor_data\";\n\n// Tạo object payload động dựa theo topic\nif (topic.includes(\"nhiet_do\")) {\n    msg.payload = {\n        nhiet_do: value\n    };\n} else if (topic.includes(\"do_am\")) {\n    msg.payload = {\n        do_am: value\n    };\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
