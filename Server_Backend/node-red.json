    {
        "id": "d0239738112e427b",
        "type": "function",
        "z": "5c5e937acc317fb2",
        "name": "Group Data",
        "func": "var rawData = msg.payload;\nvar mergedMap = {};\n\nrawData.forEach(function (item) {\n    // 1. Ép thời gian về chuẩn từng giây (Cắt bỏ phần mili-giây .xxxZ)\n    // Ví dụ: 2026-01-15T12:48:14.593Z -> 2026-01-15T12:48:14\n    var dateObj = new Date(item.time);\n    var timeKey = dateObj.toISOString().slice(0, 19);\n\n    // 2. Tạo khung chứa nếu chưa có\n    if (!mergedMap[timeKey]) {\n        mergedMap[timeKey] = {\n            time: item.time, // Giữ time gốc của dòng đầu tiên để hiển thị\n            nhiet_do: null,  // Đổi thành chữ thường cho khớp CSV\n            do_am: null      // Đổi thành chữ thường\n        };\n    }\n\n    // 3. Kiểm tra và điền dữ liệu (Chấp nhận cả tên Hoa và Thường)\n    // Kiểm tra Nhiệt độ (Nhiet_do hoặc nhiet_do)\n    var valTemp = (item.Nhiet_do !== undefined) ? item.Nhiet_do : item.nhiet_do;\n    if (valTemp !== null && valTemp !== undefined) {\n        mergedMap[timeKey].nhiet_do = valTemp;\n    }\n\n    // Kiểm tra Độ ẩm (Do_am hoặc do_am)\n    var valHumid = (item.Do_am !== undefined) ? item.Do_am : item.do_am;\n    if (valHumid !== null && valHumid !== undefined) {\n        mergedMap[timeKey].do_am = valHumid;\n    }\n});\n\n// 4. Sắp xếp lại từ mới nhất -> cũ nhất\nvar result = Object.values(mergedMap).sort(function (a, b) {\n    return new Date(b.time) - new Date(a.time);\n});\n\nmsg.payload = result;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 3,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 820,
        "wires": [
            [
                "a1990125d0c08c57"
            ]
        ]
