    {
        "id": "a1990125d0c08c57",
        "type": "function",
        "z": "5c5e937acc317fb2",
        "name": "Fix Time",
        "func": "// Lặp qua từng dòng dữ liệu lấy được từ InfluxDB\nmsg.payload = msg.payload.map(row => {\n    // 1. Lấy thời gian gốc (đang là UTC)\n    var date = new Date(row.time);\n    \n    // 2. Chuyển sang giờ Việt Nam (cộng 7 tiếng) và định dạng lại cho đẹp\n    // Kết quả sẽ ra dạng: \"2026-01-07 16:49:53\"\n    var localTime = date.toLocaleString(\"en-GB\", {\n        timeZone: \"Asia/Ho_Chi_Minh\",\n        hour12: false\n    }).replace(\",\", \"\"); // Xóa dấu phẩy giữa ngày và giờ đi cho sạch\n\n    // 3. Ghi đè lại vào trường time\n    row.time = \"'\" + localTime;\n    \n    return row;\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 940,
        "y": 840,
